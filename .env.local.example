# Copy to .env.local once you have a Sanity project. Until these are set, the
# storefront serves the local catalog in lib/products.ts (the site still works).

NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Only needed to run the one-time seed (scripts/seedSanity.ts), never committed:
# SANITY_PROJECT_ID=your-project-id
# SANITY_WRITE_TOKEN=your-editor-token
